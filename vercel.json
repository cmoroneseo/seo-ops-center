{
    "cleanUrls": true,
    "framework": "nextjs",
    "crons": [
        {
            "path": "/api/sync/metrics",
            "schedule": "0 8 * * *"
        },
        {
            "path": "/api/cron/recurring-tasks",
            "schedule": "0 9 * * *"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "X-XSS-Protection",
                    "value": "1; mode=block"
                }
            ]
        }
    ]
}